# ============================================
# APP
# ============================================
APP_URL=https://ia.amrofardamentos.com.br
APP_ENV=local
APP_TIMEZONE=America/Sao_Paulo
APP_DEBUG=true

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=amro_ia_suporte
DB_USER=root
DB_PASS=

# ============================================
# OPENAI
# ============================================
AI_PROVIDER=openai
AI_MAX_ITERATIONS=3
AI_DISABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================
# BLING V3 (OAuth 2.0)
# ============================================
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REFRESH_TOKEN=

# ============================================
# WOOCOMMERCE (REST API)
# ============================================
WC_BASE_URL=https://amrofardamentos.com.br
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

# ============================================
# MELHOR ENVIO
# ============================================
ME_BASE_URL=https://melhorenvio.com.br/api/v2
ME_ACCESS_TOKEN=

# ============================================
# KOMMO CRM
# ============================================
KOMMO_URL=https://amordepijamas1.kommo.com
KOMMO_TOKEN=
KOMMO_PIPELINE_ID=9275311
KOMMO_STATUS_PRECISA_HUMANO=

# ============================================
# WHATSAPP CLOUD API (Meta) — preencher após Fase 0
# ============================================
WHATSAPP_PROVIDER=cloud
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WABA_ID=
WHATSAPP_API_VERSION=v22.0
WHATSAPP_PAUSED=false

# ============================================
# RATE LIMIT
# ============================================
WA_RATE_DAILY_LIMIT=250
WA_RATE_JITTER_MIN_SECONDS=3
WA_RATE_JITTER_MAX_SECONDS=10

# ============================================
# REGRAS DE PRAZO AMRO
# ============================================
PRAZO_PRONTA_ENTREGA_DIAS=1
PRAZO_PRODUCAO_DIAS=15

# ============================================
# FEATURE FLAGS
# ============================================
KOMMO_NOTES_ENABLED=true
NOTIFICATION_PHONES=

# ============================================
# DASHBOARD
# ============================================
DASHBOARD_USER=admin
DASHBOARD_PASS=

# Secret pra POST /test/chat (gere aleatório, ex: openssl rand -hex 20)
TEST_ENDPOINT_SECRET=
