RewriteEngine On

# Bloqueia acesso direto a paths sensíveis
RewriteRule ^(\.git|\.env|composer\.|vendor/|src/|config/|database/|cron/|tests/|storage/|logs/|README\.md|\.htaccess$) - [F,L]

# Tudo o resto cai dentro de public/
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]

ServerSignature Off
Header always unset X-Powered-By
